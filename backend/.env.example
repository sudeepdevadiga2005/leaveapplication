# AbsentAlert — Environment Variables
# Copy this file to .env and fill in your actual values

# Flask Secret Key (change this to a random string)
SECRET_KEY=absentalert-secret-change-this-in-production

# Gmail SMTP Configuration
# Follow setup guide in EMAIL_SETUP.md
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_16_char_app_password

# Optional: Custom sender name
MAIL_DEFAULT_SENDER=AbsentAlert <your_email@gmail.com>
